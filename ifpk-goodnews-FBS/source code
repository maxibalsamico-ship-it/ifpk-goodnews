function formatNum(n) {
if (n >= 1e12) return (n/1e12).toFixed(1) + “T”;
if (n >= 1e9) return (n/1e9).toFixed(1) + “B”;
if (n >= 1e6) return (n/1e6).toFixed(1) + “M”;
if (n >= 1e3) return (n/1e3).toFixed(1) + “K”;
return Math.floor(n).toString();
}

function CookieClicker() {
const [cookies, setCookies] = useState(0);
const [cps, setCps] = useState(0);
const [owned, setOwned] = useState(upgrades.map(() => 0));
const [clickAnim, setClickAnim] = useState(false);
const [floats, setFloats] = useState([]);

useEffect(() => {
const iv = setInterval(() => {
setCookies(c => c + cps / 10);
}, 100);
return () => clearInterval(iv);
}, [cps]);

const click = () => {
setCookies(c => c + 1);
setClickAnim(true);
setTimeout(() => setClickAnim(false), 100);
const id = Date.now();
setFloats(f => […f, id]);
setTimeout(() => setFloats(f => f.filter(x => x !== id)), 800);
};

const buy = (i) => {
const cost = Math.floor(upgrades[i].cost * Math.pow(1.15, owned[i]));
if (cookies >= cost) {
setCookies(c => c - cost);
setCps(c => c + upgrades[i].cps);
setOwned(o => { const n = […o]; n[i]++; return n; });
}
};

return (
<div style={{ display:“flex”, flexDirection:“column”, height:“100%”, background:“linear-gradient(180deg,#1a0a2e,#16213e)”, color:”#fff”, padding:“12px”, overflowY:“auto” }}>
<div style={{ textAlign:“center”, marginBottom:8 }}>
<div style={{ fontSize:12, color:”#8be9fd”, letterSpacing:1, textTransform:“uppercase” }}>Cookie Clicker</div>
<div style={{ fontSize:28, fontWeight:800, color:”#f1fa8c” }}>{formatNum(cookies)}</div>
<div style={{ fontSize:11, color:”#bd93f9” }}>{formatNum(cps)} pro Sekunde</div>
</div>
<div style={{ textAlign:“center”, margin:“8px 0”, position:“relative” }}>
<button onClick={click} style={{
fontSize:56, background:“none”, border:“none”, cursor:“pointer”,
transform: clickAnim ? “scale(0.9)” : “scale(1)”,
transition:“transform 0.1s”, filter:“drop-shadow(0 0 12px rgba(241,250,140,0.5))”,
position:“relative”
}}>🍪</button>
{floats.map(id => (
<span key={id} style={{
position:“absolute”, left:“50%”, top:“30%”, pointerEvents:“none”,
animation:“floatUp 0.8s ease-out forwards”, fontSize:14, fontWeight:700, color:”#f1fa8c”
}}>+1</span>
))}
</div>
<div style={{ flex:1, overflowY:“auto” }}>
{upgrades.map((u, i) => {
const cost = Math.floor(u.cost * Math.pow(1.15, owned[i]));
const canBuy = cookies >= cost;
return (
<button key={i} onClick={() => buy(i)} style={{
display:“flex”, alignItems:“center”, gap:8, width:“100%”,
padding:“6px 8px”, marginBottom:4, borderRadius:8,
background: canBuy ? “rgba(139,233,253,0.15)” : “rgba(255,255,255,0.05)”,
border: canBuy ? “1px solid rgba(139,233,253,0.3)” : “1px solid rgba(255,255,255,0.1)”,
color: canBuy ? “#fff” : “#666”, cursor: canBuy ? “pointer” : “not-allowed”,
textAlign:“left”, transition:“all 0.2s”
}}>
<span style={{ fontSize:20 }}>{u.icon}</span>
<div style={{ flex:1 }}>
<div style={{ fontSize:12, fontWeight:600 }}>{u.name} <span style={{color:”#bd93f9”}}>x{owned[i]}</span></div>
<div style={{ fontSize:10, color:”#8be9fd” }}>{formatNum(cost)} 🍪 | +{u.cps}/s</div>
</div>
</button>
);
})}
</div>
<style>{`@keyframes floatUp { 0% { opacity:1; transform:translateX(-50%) translateY(0); } 100% { opacity:0; transform:translateX(-50%) translateY(-40px); } }`}</style>
</div>
);
}

function NewsFeed() {
