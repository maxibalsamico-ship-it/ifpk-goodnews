useEffect(() => {
if (paused) return;
const iv = setInterval(() => {
setProgress(p => {
if (p >= 100) {
setCurrentIdx(i => (i + 1) % goodNews.length);
return 0;
}
return p + 0.5;
});
}, 30);
return () => clearInterval(iv);
}, [paused]);

const visible = [];
