<span style={{ fontSize:22 }}>{n.emoji}</span>
<span style={{
fontSize:9, fontWeight:700, textTransform:“uppercase”, letterSpacing:1,
color: catColors[n.cat] || “#8be9fd”,
background: `${catColors[n.cat] || "#8be9fd"}15`,
