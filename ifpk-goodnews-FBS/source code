<div style={{ width:`${progress}%`, height:“100%”, background:“linear-gradient(90deg,#8be9fd,#bd93f9)”, borderRadius:2, transition:“width 0.03s linear” }} />
</div>
<div style={{ flex:1, display:“flex”, flexDirection:“column”, gap:10, overflow:“hidden” }} ref={scrollRef}>
{visible.map((n, i) => (
<div key={currentIdx + i} style={{
